{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["ESNext"],
    "types": ["./src/worker-configuration.d.ts", "node"],
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
