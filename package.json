{
  "name": "@iannuttall/og",
  "version": "0.1.0",
  "description": "A Cloudflare Worker template for cached Open Graph image generation.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "dev": "wrangler dev --local",
    "dev:remote": "wrangler dev --remote",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "deploy": "node scripts/deploy-config.mjs && wrangler deploy --config wrangler.deploy.jsonc",
    "deploy:dry-run": "node scripts/deploy-config.mjs && wrangler deploy --config wrangler.deploy.jsonc --dry-run",
    "examples": "node examples/generate.mjs",
    "format": "biome format --write .",
    "lint": "node scripts/check-file-lines.mjs && biome check .",
    "og": "node scripts/og.mjs",
    "security:audit": "pnpm audit --audit-level moderate",
    "security:check": "pnpm run security:audit && pnpm run security:secrets",
    "security:secrets": "node scripts/security-secrets.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types --env-file .dev.vars.example --strict-vars=false src/worker-configuration.d.ts",
    "types:check": "wrangler types --env-file .dev.vars.example --strict-vars=false src/worker-configuration.d.ts --check"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.5",
    "hono": "^4.12.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@cloudflare/vitest-pool-workers": "^0.18.3",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.109.0"
  }
}
